{
  "name": "opsnexus-desktop",
  "version": "0.1.0",
  "description": "OpsNexus Desktop - CloudOps AI Operations Assistant",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.electron.json && electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^9.0.10"
  }
}
