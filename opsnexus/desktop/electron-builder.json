{
  "appId": "com.opsnexus.desktop",
  "productName": "OpsNexus Desktop",
  "copyright": "Copyright © 2024 OpsNexus",
  "directories": {
    "buildResources": "build",
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64"] },
      { "target": "dir",  "arch": ["x64"] }
    ],
    "icon": "build/icon.png",
    "requestedExecutionLevel": "asInvoker"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "build/icon.png",
    "uninstallerIcon": "build/icon.png",
    "installerHeaderIcon": "build/icon.png",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "OpsNexus Desktop"
  },
  "mac": {
    "target": "dmg",
    "icon": "build/icon.png"
  },
  "linux": {
    "target": "AppImage",
    "icon": "build/icon.png"
  }
}
